<button
  id="theme-toggle"
  class="relative grid place-items-center p-2 max-sm:p-3 rounded-full text-text-muted hover:text-accent hover:bg-accent/10 hover:scale-110 active:scale-90 transition-[transform,color,background-color,box-shadow] duration-200 active:duration-100"
  aria-label="Theme wechseln"
>
  <svg id="sun-icon" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
    <circle cx="12" cy="12" r="5" />
    <path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42" />
  </svg>
  <svg id="moon-icon" class="w-5 h-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
  </svg>
</button>

<style lang="scss">
  // Icons via CSS Grid stapeln – beide liegen übereinander
  #theme-toggle > svg {
    grid-area: 1 / 1;
  }

  // Sanfte Sonne↔Mond Transition mit Overshoot
  #sun-icon, #moon-icon {
    transition: transform 150ms cubic-bezier(0.34, 1.56, 0.64, 1), opacity 150ms ease-out;
  }

  #sun-icon.hidden {
    opacity: 0;
    transform: scale(0.3) rotate(180deg);
    pointer-events: none;
  }

  #moon-icon.hidden {
    opacity: 0;
    transform: scale(0.3) rotate(-180deg);
    pointer-events: none;
  }

  // Glow-Effekt beim Theme-Toggle
  .theme-glow {
    box-shadow: 0 0 16px var(--color-accent-glow);
  }
</style>

<script>
  const btn = document.getElementById('theme-toggle');
  const sun = document.getElementById('sun-icon');
  const moon = document.getElementById('moon-icon');

  function applyTheme() {
    const html = document.documentElement;
    const theme = localStorage.getItem('theme') || 'light';
    html.classList.toggle('dark', theme === 'dark');
    sun.classList.toggle('hidden', theme === 'dark');
    moon.classList.toggle('hidden', theme === 'light');
  }

  // Erstmaliges Anwenden
  applyTheme();

  // Nach jeder View Transition erneut anwenden – <html> ist frisch,
  // aber Button/Icons persistieren via transition:persist im Header
  document.addEventListener('astro:after-swap', applyTheme);

  btn.addEventListener('click', () => {
    const html = document.documentElement;
    const isDark = html.classList.toggle('dark');
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
    sun.classList.toggle('hidden', isDark);
    moon.classList.toggle('hidden', !isDark);

    /* Glow-Pulse: kurzer Leuchteffekt beim Toggle */
    btn.classList.add('theme-glow');
    setTimeout(() => {
      btn.classList.remove('theme-glow');
    }, 400);
  });
</script>

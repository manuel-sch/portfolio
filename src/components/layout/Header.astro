---
import ThemeToggle from './ThemeToggle.astro';

const navItems = [
  { href: '/', label: 'Start' },
  { href: '/lebenslauf', label: 'Lebenslauf' },
  { href: '/projekte', label: 'Projekte' },
];
const currentPath = Astro.url.pathname;
---

<header
  class="fixed top-0 left-0 right-0 z-50 backdrop-blur-xl bg-bg/70 border-b border-border"
>
  <nav class="max-w-5xl mx-auto px-6 h-14 flex items-center justify-between">
    <a href="/" class="text-sm font-bold tracking-tight text-text dark:text-text-dark font-heading">
      MS
    </a>
    <div class="flex items-center gap-6">
      <ul class="flex gap-6 text-sm">
        {navItems.map(item => (
          <li>
            <a
              href={item.href}
              class={`nav-link relative inline-block pb-0.5 transition-[transform,color] duration-200 active:duration-100 hover:scale-[1.02] active:scale-95 hover:text-accent dark:hover:text-accent-dark
                ${currentPath === item.href
                  ? 'text-accent dark:text-accent-dark'
                  : 'text-text-muted dark:text-text-muted-dark'}`}
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
      <ThemeToggle />
    </div>
  </nav>
</header>

<style>
  .nav-link::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: 0;
    width: 100%;
    height: 1.5px;
    background: var(--color-accent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 300ms cubic-bezier(0.4, 0, 0.2, 1);
  }

  .nav-link:hover::after {
    transform: scaleX(1);
  }
</style>

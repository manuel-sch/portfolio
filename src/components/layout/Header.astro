---
import ThemeToggle from './ThemeToggle.astro';

const navItems = [
  { href: '/', label: 'Start' },
  { href: '/lebenslauf', label: 'Lebenslauf' },
  { href: '/projekte', label: 'Projekte' },
];
const currentPath = Astro.url.pathname;
---

<header
  class="fixed top-0 left-0 right-0 z-50 backdrop-blur-xl bg-bg/70 border-b border-border"
>
  <nav class="max-w-5xl mx-auto px-6 h-14 flex items-center justify-between">
    <a href="/" class="text-sm font-bold tracking-tight text-text dark:text-text-dark font-heading">
      MS
    </a>
    <div class="flex items-center gap-6">
      <ul class="flex gap-6 text-sm">
        {navItems.map(item => (
          <li>
            <a
              href={item.href}
              class={`transition-colors duration-200 hover:text-accent dark:hover:text-accent-dark
                ${currentPath === item.href
                  ? 'text-accent dark:text-accent-dark'
                  : 'text-text-muted dark:text-text-muted-dark'}`}
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
      <ThemeToggle />
    </div>
  </nav>
</header>

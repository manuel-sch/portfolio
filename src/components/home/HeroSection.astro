---

<section class="min-h-screen flex items-center px-6 pt-14">
  <div class="max-w-5xl mx-auto w-full grid md:grid-cols-[1fr_auto] gap-8 md:gap-12 xl:gap-16 items-center">

    <!-- Portrait Card (auf Mobile über dem Text, via order) -->
    <div class="mx-auto md:mx-0 order-1 md:order-2">
      <div class="relative rounded-2xl backdrop-blur-xl bg-surface/60 border border-border
                  shadow-lg w-56 h-64 md:w-72 md:h-80 xl:w-80 xl:h-96 overflow-hidden">
        <div class="absolute -top-3 -right-3 w-20 h-20 md:w-24 md:h-24 rounded-full bg-accent/20 blur-2xl"></div>
        <div class="absolute -bottom-4 -left-4 w-28 h-28 md:w-32 md:h-32 rounded-full bg-accent/10 blur-3xl"></div>
        <img
          src="/images/portrait.png"
          alt="Manuel Scholtes"
          class="w-full h-full object-cover"
        />
      </div>
    </div>

    <!-- Text (auf Desktop links, auf Mobile unter dem Portrait) -->
    <div class="space-y-6 order-2 md:order-1 text-center md:text-left">
      <p class="text-sm text-text-muted font-medium tracking-wide uppercase">
        B.Sc. Software Engineer
      </p>
      <h1 class="text-5xl md:text-7xl xl:text-8xl font-bold tracking-tight font-heading leading-none">
        Manuel<br />Scholtes
      </h1>
      <p class="text-lg text-text-muted max-w-md mx-auto md:mx-0 leading-relaxed">
        Softwareentwicklung mit Leidenschaft für saubere Architektur und moderne Technologien.
      </p>
      <div class="flex flex-wrap justify-center md:justify-start gap-3 pt-4">
        <a href="https://github.com/manuel-sch" target="_blank" rel="noopener"
           class="inline-flex items-center justify-center gap-2 px-5 min-h-[44px] rounded-full border border-border
                  text-sm font-medium text-text hover:bg-surface-hover hover:scale-[1.02] active:scale-95 transition-[transform,color,background-color] duration-200 active:duration-100">
          GitHub
        </a>
        <a href="https://linkedin.com/in/manuel-scholtes-493230270" target="_blank" rel="noopener"
           class="inline-flex items-center justify-center gap-2 px-5 min-h-[44px] rounded-full border border-border
                  text-sm font-medium text-text hover:bg-surface-hover hover:scale-[1.02] active:scale-95 transition-[transform,color,background-color] duration-200 active:duration-100">
          LinkedIn
        </a>
        <a href="mailto:manuel-scholtes@web.de"
           class="inline-flex items-center justify-center gap-2 px-5 min-h-[44px] rounded-full
                  bg-accent text-white text-sm font-medium
                  hover:bg-accent-light hover:scale-[1.02] active:scale-95 transition-[transform,color,background-color] duration-200 active:duration-100">
          Kontakt
        </a>
      </div>
    </div>

  </div>
</section>

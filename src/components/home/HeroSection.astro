<section class="min-h-screen flex items-center px-6 pt-14">
  <div class="max-w-5xl mx-auto w-full grid md:grid-cols-[1fr_auto] gap-12 items-center">
    <!-- Text -->
    <div class="space-y-6">
      <p class="text-sm text-text-muted font-medium tracking-wide uppercase">
        B.Sc. Software Engineer
      </p>
      <h1 class="text-5xl md:text-7xl font-bold tracking-tight font-heading leading-none">
        Manuel<br />Scholtes
      </h1>
      <p class="text-lg text-text-muted max-w-md leading-relaxed">
        Softwareentwicklung mit Leidenschaft für saubere Architektur und moderne Technologien.
      </p>
      <div class="flex gap-4 pt-4">
        <a href="https://github.com/manuel-sch" target="_blank" rel="noopener"
           class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full border border-border
                  text-sm font-medium text-text hover:bg-surface-hover hover:scale-[1.02] active:scale-95 transition-[transform,color,background-color] duration-200 active:duration-100">
          GitHub
        </a>
        <a href="https://linkedin.com/in/manuel-scholtes-493230270" target="_blank" rel="noopener"
           class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full border border-border
                  text-sm font-medium text-text hover:bg-surface-hover hover:scale-[1.02] active:scale-95 transition-[transform,color,background-color] duration-200 active:duration-100">
          LinkedIn
        </a>
        <a href="mailto:manuel-scholtes@web.de"
           class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full
                  bg-accent text-white text-sm font-medium
                  hover:bg-accent-light hover:scale-[1.02] active:scale-95 transition-[transform,color,background-color] duration-200 active:duration-100">
          Kontakt
        </a>
      </div>
    </div>

    <!-- Portrait Card -->
    <div class="hidden md:block">
      <div class="relative rounded-2xl backdrop-blur-xl bg-surface/60 border border-border
                  shadow-lg w-72 h-80 overflow-hidden">
        <div class="absolute -top-3 -right-3 w-24 h-24 rounded-full bg-accent/20 blur-2xl"></div>
        <div class="absolute -bottom-4 -left-4 w-32 h-32 rounded-full bg-accent/10 blur-3xl"></div>
        <img
          src="/images/portrait.png"
          alt="Manuel Scholtes"
          class="w-full h-full object-cover"
        />
      </div>
    </div>
  </div>
</section>

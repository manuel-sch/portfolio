---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SectionBadge from '@/components/cv/SectionBadge.astro';
import {getBadgeUrl} from '@/lib/techBadges';
import {experience, skills, education} from '@/data/cv-data';
import { pageTransition } from '@/lib/transitions';

const categories = [...new Set(skills.map(s => s.category))];
---

<BaseLayout>
    <main transition:name="page-content" transition:animate={pageTransition} class="max-w-5xl mx-auto px-6 pb-20 sm:pb-32">
        <div class="space-y-16 sm:space-y-24">

            <!-- Berufserfahrung – Card Stack mit Crossfade -->
            <section id="timeline-section" class="relative" style={`height: ${experience.length * 100}vh`}>
                <div class="sticky top-0 h-screen flex flex-col items-center justify-center">
                    <div class="mb-8 sm:mb-10">
                        <SectionBadge title="Berufserfahrung"/>
                    </div>
                    <div id="card-stage" class="relative w-full max-w-lg sm:max-w-xl md:max-w-2xl h-[450px] sm:h-[400px]">
                        {experience.map((exp, i) => (
                                <div class="timeline-card absolute inset-0 flex items-center justify-center"
                                     style={`opacity: ${i === 0 ? 1 : 0}`}>
                                    <div
                                            class="rounded-2xl backdrop-blur-xl bg-surface/80 border border-border p-4 sm:p-6 md:p-8 w-full shadow-2xl relative overflow-hidden">
                                        <!-- Role + EmploymentType -->
                                        <div class="mb-4 text-center">
                                            <h2 class="text-xl sm:text-2xl md:text-3xl font-bold font-heading text-text">{exp.role}</h2>
                                            {exp.employmentType && (
                                                    <span class="text-sm text-text-muted font-medium">{exp.employmentType}</span>
                                            )}
                                        </div>

                                        <!-- Description -->
                                        <ul class="space-y-1.5 text-sm sm:text-base text-text-muted leading-relaxed text-center">
                                            {exp.description.map(item =>
                                                    <li>— {item}</li>)}
                                        </ul>

                                        <!-- Tech Badges -->
                                        <div class="flex flex-wrap justify-center gap-2 mt-4 sm:mt-5">
                                            {exp.techStack.map(tech => <img src={getBadgeUrl(tech)} alt={tech}
                                                                            class="h-5 w-auto inline-block rounded"
                                                                            loading="lazy"/>)}
                                        </div>

                                        <!-- Logo + Company + LinkedIn (unten, zentriert) -->
                                        <div class="mt-4 sm:mt-5 pt-4 border-t border-border/50">
                                            <div class="flex flex-col items-center gap-1.5">
                                                {exp.logo && (
                                                        <img src={exp.logo} alt={exp.company}
                                                             class="h-7 w-auto object-contain opacity-70"/>
                                                )}
                                                <span class="text-xs text-text-muted font-medium inline-flex items-center gap-1.5">
                            {exp.company}
                                                    {exp.linkedinUrl && (
                                                            <a href={exp.linkedinUrl} target="_blank"
                                                               rel="noopener noreferrer"
                                                               class="text-text-muted hover:text-accent-light transition-colors duration-200 leading-none"
                                                               title={`${exp.company} auf LinkedIn`}
                                                               aria-label={`${exp.company} auf LinkedIn`}>
                                                                <svg class="w-5 h-5" viewBox="0 0 24 24"
                                                                     fill="currentColor">
                                                                    <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                                                                </svg>
                                                            </a>
                                                    )}
                          </span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                        ))}
                    </div>

                    <!-- Tab-Indikator – horizontal unter den Cards -->
                    <nav id="timeline-tabs" class="mt-6 sm:mt-8 flex flex-nowrap overflow-x-auto touch-pan-x gap-2 sm:gap-3 px-4 scrollbar-hide" aria-label="Berufserfahrung Navigation">
                        {experience.map((exp, i) => (
                                <button
                                        class="timeline-tab group relative px-3 py-2 sm:px-4 sm:py-2.5 rounded-xl transition-all duration-300 cursor-pointer text-left bg-surface/40 hover:bg-surface/60"
                                        data-index={i}
                                        style={`opacity: ${i === 0 ? '1' : '0.4'}`}
                                        aria-label={`${exp.role} bei ${exp.company}`}
                                >
                            <span class="block text-[10px] sm:text-xs font-medium text-accent-light uppercase tracking-wider leading-tight">{exp.period}</span>
                            <span class="block text-xs sm:text-sm font-semibold text-text mt-0.5 leading-tight">{exp.company}</span>
                        </button>
                        ))}
                    </nav>

                    <!-- Scroll Hint -->
                    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 flex flex-col items-center gap-1 text-text-muted animate-pulse">
                        <span class="text-xs uppercase tracking-widest">Scrollen</span>
                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path d="M7 13l5 5 5-5M7 6l5 5 5-5"/>
                        </svg>
                    </div>
                </div>
            </section>

            <!-- Skills -->
            <section>
                <div class="flex justify-center">
                    <SectionBadge title="Skills"/>
                </div>
                <div class="grid md:grid-cols-2 xl:grid-cols-4 gap-6 sm:gap-8">
                    {categories.map(category => (
                            <div class="rounded-2xl backdrop-blur-xl bg-surface/70 border border-border p-6">
                                <p class="text-xs font-semibold text-accent uppercase tracking-wider mb-5">{category}</p>
                                <div class="space-y-4">
                                    {skills.filter(s => s.category === category).map(skill => (
                                            <div class="skill-item">
                                                <div class="flex justify-between text-sm mb-1.5">
                                                    <span class="text-text font-medium">{skill.name}</span>
                                                    <span class="skill-counter text-text-muted"
                                                          data-target={skill.level}>0%</span>
                                                </div>
                                                <div class="h-1.5 rounded-full bg-surface overflow-visible">
                                                    <div class="skill-bar h-full rounded-full bg-accent"
                                                         style="width: 0%" data-width={skill.level}></div>
                                                </div>
                                            </div>
                                    ))}
                                </div>
                            </div>
                    ))}
                </div>
            </section>

            <!-- Ausbildung -->
            <section>
                <div class="flex justify-center">
                    <SectionBadge title="Ausbildung"/>
                </div>
                <div class="space-y-3">
                    {education.map(edu => (
                            <div class="rounded-2xl backdrop-blur-xl bg-surface/70 border border-border p-5 sm:p-6 flex flex-col sm:flex-row sm:items-center justify-between gap-2">
                                <div>
                                    <h3 class="font-semibold text-text">{edu.degree}</h3>
                                    <p class="text-sm text-text-muted">{edu.school}</p>
                                </div>
                                <div class="flex gap-4 text-xs text-text-muted shrink-0">
                                    <span>{edu.period}</span>
                                    {edu.note && <span class="text-accent-light font-medium">{edu.note}</span>}
                                </div>
                            </div>
                    ))}
                </div>
            </section>

            <!-- Sprachen -->
            <section>
                <div class="flex justify-center">
                    <SectionBadge title="Sprachen"/>
                </div>
                <div class="flex flex-wrap justify-center gap-3">
                    <span class="px-5 py-3 rounded-full bg-accent/10 text-accent-light text-sm font-medium">Deutsch – Muttersprache</span>
                    <span class="px-5 py-3 rounded-full bg-surface/70 backdrop-blur-xl border border-border text-text text-sm font-medium">Englisch – Gute Kenntnisse</span>
                </div>
            </section>

        </div>
    </main>
</BaseLayout>

<style>
    @keyframes skill-pulse {
        0% {
            transform: scaleY(1);
            filter: brightness(1);
        }
        40% {
            transform: scaleY(1.35);
            filter: brightness(1.12);
        }
        100% {
            transform: scaleY(1);
            filter: brightness(1);
        }
    }

    .skill-bar.pulse {
        animation: skill-pulse 400ms ease-out;
    }

    /* Transition erst nach JS-Initialisierung aktiv – verhindert Flash beim Seitenaufbau */
    #timeline-section:not(.ready) .timeline-card {
        transition: none;
    }

    #timeline-section.ready .timeline-card {
        transition: opacity 600ms cubic-bezier(0.16, 1, 0.3, 1);
    }

    /* Scrollbar visuell ausblenden, aber funktional lassen */
    .scrollbar-hide {
        -ms-overflow-style: none;  /* IE/Edge */
        scrollbar-width: none;     /* Firefox */
    }

    .scrollbar-hide::-webkit-scrollbar {
        display: none;             /* Chrome/Safari */
    }
</style>

<script src="../scripts/lebenslauf.ts"></script>

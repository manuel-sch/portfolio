---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SectionBadge from '@/components/cv/SectionBadge.astro';
import { getBadgeUrl } from '@/lib/techBadges';
import { experience, skills, education } from '@/data/cv-data';

const categories = [...new Set(skills.map(s => s.category))];
---

<BaseLayout>
  <main class="max-w-5xl mx-auto px-6 wpb-32">
    <div class="space-y-24">

      <!-- Berufserfahrung – Single Card + Text Indicator -->
      <section id="timeline-section" class="relative" style="height: 700vh">
        <div class="sticky top-0 h-screen flex items-center pt-14">
          <div class="w-full px-6 flex items-center justify-center">
            <!-- Card -->
            <div id="card-stage" class="relative w-full max-w-3xl" style="height: 440px">
              {experience.map((exp, i) => (
                <div
                  class="timeline-card absolute inset-0 flex items-center justify-center"
                  data-index={i}
                  style:opacity={i === 0 ? '1' : '0'}
                  style:transform={i === 0 ? 'translateY(0) scale(1)' : 'translateY(60px) scale(0.92)'}
                  style:pointer-events={i === 0 ? 'auto' : 'none'}
                  style:visibility={i === 0 ? 'visible' : 'hidden'}
                  style:transition="none"
                >
                  <div class="rounded-2xl backdrop-blur-xl bg-surface/80 border border-border p-6 md:p-8 w-full shadow-2xl relative overflow-hidden">
                    <div class="card-glow absolute inset-0 bg-accent/5 opacity-0 transition-opacity duration-700"></div>
                    <div class="flex justify-between items-start gap-4 mb-4">
                      <div>
                        <h2 class="text-3xl font-bold font-heading text-text">{exp.role}</h2>
                        {exp.employmentType && (
                          <span class="text-sm text-text-muted font-medium">{exp.employmentType}</span>
                        )}
                      </div>
                      {exp.logo && (
                        <div class="flex flex-col items-end gap-1 shrink-0">
                          <img src={exp.logo} alt={exp.company} class="h-7 w-auto object-contain opacity-70" />
                          <span class="text-xs text-text-muted font-medium">{exp.company}</span>
                        </div>
                      )}
                    </div>
                    <ul class="mt-6 space-y-1.5 text-base text-text-muted leading-relaxed">
                      {exp.description.map(item => <li>— {item}</li>)}
                    </ul>
                    <div class="flex flex-wrap gap-2 mt-5">
                      {exp.techStack.map(tech => <img src={getBadgeUrl(tech)} alt={tech} class="h-5 w-auto inline-block rounded" loading="lazy" />)}
                  </div>
                  </div>
                </div>
            ))}
            <!-- Text Indicator -->
            <div class="absolute left-full ml-6 top-0 h-full hidden lg:flex flex-col gap-3 w-40 justify-center">
              {experience.map((exp, i) => (
                <button
                  class="timeline-indicator text-left py-2 px-3 rounded-lg transition-all duration-300 border-0 cursor-pointer"
                  data-index={i}
                  style:opacity={i === 0 ? '1' : '0.25'}
                >
                  <span class="block text-xs font-medium text-accent-light uppercase tracking-wider">{exp.period}</span>
                  <span class="block text-sm font-semibold text-text mt-0.5">{exp.company}</span>
                </button>
              ))}
            </div>
            </div>
          </div>
          <!-- Scroll Hint -->
          <div class="absolute bottom-2 left-1/2 -translate-x-1/2 flex flex-col items-center gap-1 text-text-muted animate-pulse">
            <span class="text-xs uppercase tracking-widest">Scrollen</span>
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path d="M7 13l5 5 5-5M7 6l5 5 5-5" />
            </svg>
          </div>
        </div>
      </section>

      <!-- Skills -->
      <section>
        <SectionBadge title="Skills" />
        <div class="grid md:grid-cols-2 gap-8">
          {categories.map(category => (
            <div class="rounded-2xl backdrop-blur-xl bg-surface/70 border border-border p-6">
              <p class="text-xs font-semibold text-accent uppercase tracking-wider mb-5">{category}</p>
              <div class="space-y-4">
                {skills.filter(s => s.category === category).map(skill => (
                  <div class="skill-item">
                    <div class="flex justify-between text-sm mb-1.5">
                      <span class="text-text font-medium">{skill.name}</span>
                      <span class="skill-counter text-text-muted" data-target={skill.level}>0%</span>
                    </div>
                    <div class="h-1.5 rounded-full bg-surface overflow-hidden">
                      <div class="skill-bar h-full rounded-full bg-accent" style="width: 0%" data-width={skill.level}></div>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          ))}
        </div>
      </section>

      <!-- Ausbildung -->
      <section>
        <SectionBadge title="Ausbildung" />
        <div class="space-y-3">
          {education.map(edu => (
            <div class="rounded-2xl backdrop-blur-xl bg-surface/70 border border-border p-6 flex flex-col sm:flex-row sm:items-center justify-between gap-2">
              <div>
                <h3 class="font-semibold text-text">{edu.degree}</h3>
                <p class="text-sm text-text-muted">{edu.school}</p>
              </div>
              <div class="flex gap-4 text-xs text-text-muted shrink-0">
                <span>{edu.period}</span>
                {edu.note && <span class="text-accent-light font-medium">{edu.note}</span>}
              </div>
            </div>
          ))}
        </div>
      </section>

      <!-- Sprachen -->
      <section>
        <SectionBadge title="Sprachen" />
        <div class="flex flex-wrap gap-3">
          <span class="px-5 py-3 rounded-full bg-accent/10 text-accent-light text-sm font-medium">Deutsch – Muttersprache</span>
          <span class="px-5 py-3 rounded-full bg-surface/70 backdrop-blur-xl border border-border text-text text-sm font-medium">Englisch – Gute Kenntnisse</span>
        </div>
      </section>

    </div>
  </main>
</BaseLayout>

<script src="../scripts/lebenslauf.ts"></script>

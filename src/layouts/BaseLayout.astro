---
import { ViewTransitions } from 'astro:transitions';
import '@/styles/global.css';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <ViewTransitions />
    <title>Manuel Scholtes</title>

    <!-- Favicon: SVG mit transparentem Hintergrund (funktioniert auf hellen & dunklen Tabs) -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Favicon: PNG Fallback (ältere Browser, Windows-Shortcuts, Social Previews) -->
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon.png" />

    <!-- Web App Manifest (Android Chrome, PWA) -->
    <link rel="manifest" href="/site.webmanifest" />

    <!-- Theme Color: Browser-Chrome in Brand-Farbe -->
    <meta name="theme-color" content="#0E0E10" />
  </head>
  <body class="bg-bg text-text">
    <Header />
    <slot />
    <Footer />
  </body>
</html>
